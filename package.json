{
  "name": "livechat-root",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "description": "Root tooling for the AFixt livechat monorepo (api, ui, widget, shared, usecases).",
  "engines": {
    "node": ">=22 <23"
  },
  "workspaces": [
    "shared",
    "api",
    "ui",
    "widget",
    "e2e"
  ],
  "overrides": {
    "zod": "4.3.6",
    "vite": "7.3.6",
    "@afixt/usecase-runner": {
      "zod": "3.25.76"
    },
    "@afixt/a11y-assert": "2.1.3",
    "@babel/core": "^7.29.6",
    "basic-ftp": "^5.3.1",
    "brace-expansion@^5.0.0": "^5.0.6",
    "brace-expansion@^1.0.0": "^1.1.16",
    "brace-expansion@^2.0.0": "^2.1.2",
    "esbuild@>=0.26.0": "^0.28.1",
    "fast-uri": "^3.1.2",
    "form-data": "^4.0.6",
    "ip-address": "^10.1.1",
    "js-cookie": "^3.0.7",
    "js-yaml@^4.0.0": "^4.2.0",
    "linkify-it": "^5.0.1",
    "markdown-it": "^14.2.0",
    "qs": "^6.15.2",
    "shell-quote": "^1.8.4",
    "undici": "^7.28.0",
    "uuid@^13.0.0": "^13.0.1",
    "ws": "^8.21.0",
    "yaml@^2.0.0": "^2.8.3",
    "sequelize": {
      "uuid": "^11.1.1"
    },
    "engine.io": "^6.6.7"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "npm-run-all -p dev:*",
    "dev:api": "npm --workspace api run dev",
    "dev:ui": "npm --workspace ui run dev",
    "dev:widget": "npm --workspace widget run dev",
    "build": "npm-run-all -s build:shared build:api build:ui build:widget",
    "build:shared": "npm --workspace shared run build",
    "build:api": "npm --workspace api run build",
    "build:ui": "npm --workspace ui run build",
    "build:widget": "npm --workspace widget run build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "npm-run-all -p typecheck:*",
    "typecheck:shared": "npm --workspace shared run typecheck",
    "typecheck:api": "npm --workspace api run typecheck",
    "typecheck:ui": "npm --workspace ui run typecheck",
    "typecheck:widget": "npm --workspace widget run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"**/*.{css,scss}\" --allow-empty-input --max-warnings=0",
    "stylelint:fix": "stylelint \"**/*.{css,scss}\" --allow-empty-input --fix",
    "markdownlint": "markdownlint-cli2 \"**/*.md\" \"#**/node_modules/**\"",
    "markdownlint:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#**/node_modules/**\"",
    "dupes": "jscpd",
    "links": "lychee --no-progress '**/*.md'",
    "test": "npm-run-all -s test:shared test:api test:ui test:widget",
    "test:shared": "npm --workspace shared run test",
    "test:api": "npm --workspace api run test",
    "test:ui": "npm --workspace ui run test:unit",
    "test:widget": "npm --workspace widget run test:unit",
    "test:e2e": "npm-run-all -s usecases:generate test:e2e:journeys test:e2e:ui test:e2e:widget",
    "test:e2e:ui": "npm --workspace ui run test:e2e",
    "test:e2e:widget": "npm --workspace widget run test:e2e",
    "usecases:validate": "usecase-runner validate usecases/",
    "usecases:generate": "npm-run-all -s usecases:generate:ui usecases:generate:widget",
    "usecases:generate:ui": "usecase-runner generate usecases/support --outdir ui/e2e/generated && usecase-runner generate usecases/admin --outdir ui/e2e/generated",
    "usecases:generate:widget": "usecase-runner generate usecases/widget --outdir widget/e2e/generated",
    "size": "npm-run-all -s size:widget size:ui",
    "size:widget": "npm --workspace widget run size",
    "size:ui": "npm --workspace ui run size",
    "lhci": "lhci autorun",
    "load": "artillery run scripts/load/visitor-burst.yml",
    "security:audit": "npm audit --workspaces --include-workspace-root --audit-level=high",
    "security:osv": "osv-scanner --lockfile=package-lock.json",
    "security:semgrep": "bash scripts/semgrep.sh",
    "security:secrets": "trufflehog git file://. --results=verified --fail --no-update",
    "security": "npm-run-all -p security:audit security:osv security:semgrep security:secrets",
    "license:check": "license-checker-rseidelsohn --production --onlyAllow 'MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;Unlicense;Python-2.0;WTFPL;BlueOak-1.0.0' --excludePrivatePackages --summary",
    "license:report": "license-checker-rseidelsohn --production --csv --out reports/licenses.csv",
    "check": "npm-run-all -p lint typecheck stylelint markdownlint usecases:validate",
    "check:all": "npm-run-all -s check test build size dupes links security license:check",
    "ci": "npm run check:all",
    "test:e2e:journeys": "npm --workspace @livechat/e2e run test"
  },
  "devDependencies": {
    "@afixt/usecase-runner": "1.3.2",
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@double-great/stylelint-a11y": "3.4.10",
    "@eslint/js": "9.39.4",
    "@total-typescript/ts-reset": "0.6.1",
    "@typescript-eslint/parser": "8.59.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-no-secrets": "2.3.3",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "15.15.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "jscpd": "4.0.5",
    "license-checker-rseidelsohn": "4.4.2",
    "lint-staged": "15.3.0",
    "markdownlint-cli2": "0.17.1",
    "npm-run-all": "4.1.5",
    "prettier": "3.4.2",
    "prettier-plugin-organize-imports": "4.1.0",
    "stylelint": "17.9.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-declaration-strict-value": "1.11.1",
    "tsc-files": "1.1.4",
    "typescript": "5.7.2",
    "typescript-eslint": "8.59.0"
  }
}
