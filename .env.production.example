# Copy to .env.production and fill in real values. Never commit .env.production.
# Every variable here is required (empty values → app fails to boot, by design).

# Public URLs — where each surface is actually reachable.
APP_URL=https://console.livechat.example.com
API_URL=https://api.livechat.example.com
WIDGET_URL=https://widget.livechat.example.com

# MySQL (self-hosted compose — uses the internal `mysql` service name).
DB_NAME=livechat
DB_USER=livechat
DB_PASS=                # SECRET — generate a long random password
MYSQL_ROOT_PASSWORD=    # SECRET — different from DB_PASS

# Cryptographic secrets — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=      # SECRET
JWT_REFRESH_SECRET=     # SECRET — must be different from JWT_ACCESS_SECRET
COOKIE_SECRET=          # SECRET — used to sign the visitor cookie

# SMTP — for invitation + verification + password-reset + transcript emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=no-reply@example.com

# S3-compatible storage for chat attachments. Use AWS, MinIO, DO Spaces, etc.
S3_ENDPOINT=            # Leave empty for AWS S3 default
S3_REGION=us-east-1
S3_ACCESS_KEY=          # SECRET
S3_SECRET_KEY=          # SECRET
S3_BUCKET=livechat-attachments

# Logging.
LOG_LEVEL=info
